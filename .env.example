# 必填：API 配置加密密钥；代码接受任意非空字符串，生产环境建议至少 16 字符且随机。
# 不要把真实密钥提交到仓库、镜像或聊天记录中。
ZHIDA_CONFIG_SECRET=your-secret-key-here-change-me

# 可选：Node 后端监听地址。
# 默认：本地 127.0.0.1；Dockerfile.server 内为 0.0.0.0。
# ZHIDA_HOST=127.0.0.1

# 可选：Node 后端监听端口，有效范围 1-65535。
# 默认：3000。注意服务端读取 ZHIDA_PORT，不读取 PORT。
# ZHIDA_PORT=3000

# 可选：加密配置文件路径。
# 默认：本地 .zhida-data/config.enc.json；Dockerfile.server/Compose 为 /data/config.enc.json。
# 注意服务端读取 ZHIDA_CONFIG_PATH，不读取 CONFIG_PATH。
# ZHIDA_CONFIG_PATH=.zhida-data/config.enc.json

# 可选：旧 Docker 配置的只读兼容路径，保存时不会写回此路径。
# 默认：server/data/config.enc.json；容器内对应 /app/server/data/config.enc.json。
# LEGACY_DOCKER_CONFIG_PATH=server/data/config.enc.json

# 可选：上游代理超时，单位毫秒，必须是 1 到 9007199254740991 之间的整数。
# 默认：120000。
# ZHIDA_PROXY_TIMEOUT_MS=120000

# 可选：/api/chat/completions 和 /api/responses 的请求体上限，单位字节，必须是 1 到 9007199254740991 之间的整数。
# 服务端默认：26214400；Docker Compose 未设置时会传入 10485760。
# ZHIDA_PROXY_MAX_BODY_BYTES=26214400

# 可选：测试页开关；只有字面量 1 会开放 /tests/smoke.html。
# 生产环境不要启用。
# ZHIDA_ENABLE_TEST_ROUTES=1

# Docker Compose 可选：发布到宿主机的绑定 IP。
# 默认：127.0.0.1。设为 0.0.0.0 会暴露到宿主机所有网卡。
# ZHIDA_HOST_IP=127.0.0.1

# Docker Compose 可选：发布到宿主机的端口。
# 默认：3000。
# ZHIDA_HOST_PORT=3000

# Docker 构建可选：Node 基础镜像版本，项目要求 Node.js 20+。
# 默认：22。
# NODE_VERSION=22
