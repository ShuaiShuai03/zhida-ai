ARG NODE_VERSION=22
FROM node:${NODE_VERSION}-alpine

LABEL maintainer="ZhiDa AI Contributors"
LABEL description="智答 AI Node proxy mode"

WORKDIR /app

COPY index.html ./
COPY css/ ./css/
COPY js/ ./js/
COPY assets/ ./assets/
COPY server/server.js ./server/server.js

ENV ZHIDA_PORT=3000
ENV ZHIDA_HOST=0.0.0.0
ENV ZHIDA_CONFIG_PATH=/data/config.enc.json

RUN mkdir -p /data && chown -R node:node /app /data

USER node

EXPOSE 3000
CMD ["node", "server/server.js"]
