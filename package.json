{
  "name": "zhida-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local-first OpenAI-compatible Q&A workspace with a Windows desktop shell.",
  "author": "ShuaiShuai03",
  "license": "MIT",
  "homepage": "https://github.com/ShuaiShuai03/zhida-ai#readme",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node server/server.js",
    "test": "node --test tests/*.test.mjs",
    "desktop": "electron .",
    "desktop:dev": "electron .",
    "desktop:smoke": "node scripts/run_desktop_smoke.mjs",
    "desktop:audit": "node scripts/audit_desktop_package.mjs",
    "desktop:dir": "electron-builder --dir",
    "desktop:build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "@electron/asar": "3.4.1",
    "electron": "^42.4.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.zhida.ai",
    "productName": "智答 AI",
    "asar": true,
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "index.html",
      "css/**",
      "js/**",
      "assets/**",
      "vendor/**",
      "server/server.js",
      "desktop/**",
      "package.json",
      "!**/.env",
      "!**/.env.*",
      "!**/.zhida-data/**",
      "!**/server/data/**",
      "!**/*.enc.json",
      "!**/logs/**",
      "!**/*.log",
      "!tests/**",
      "!specs/**",
      "!scripts/**",
      "!Dockerfile*",
      "!docker-compose*.yml",
      "!.github/**",
      "!.codex/**",
      "!.agents/**"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
